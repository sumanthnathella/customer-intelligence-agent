# ── Agent (read plane): OpenRouter Nemotron ──────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
AGENT_MODEL=openrouter/nvidia/nemotron-3-ultra:free
AGENT_FALLBACK_MODEL=ollama_chat/gemma4:31b

# ── Build plane: local Ollama (bulk tagging + embeddings) ────────────────
OLLAMA_API_BASE=http://localhost:11434
TAGGING_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# ── Pipeline params ──────────────────────────────────────────────────────
BUILD_TWEET_LIMIT=1000000        # ~1M tweets for build; rest reserved for test batches
TAG_SAMPLE_SIZE=10000            # stratified sample to LLM-tag
MAX_L5_LEAVES=100                # taxonomy cap
ZSCORE_BASELINE_WEEKS=8          # trailing window for spike detection
RANDOM_SEED=42

# ── Disable Vertex / GCP (local + OpenRouter only) ───────────────────────
GOOGLE_GENAI_USE_VERTEXAI=False
